# Web Reader — environment example
# Copy this to .env for local overrides (not required; keys can be set in the UI)

# OpenAI API key (used for TTS if set here; otherwise enter in Settings)
OPENAI_API_KEY=sk-...

# ElevenLabs API key
ELEVENLABS_API_KEY=...

# Default CORS proxy (used in production builds)
VITE_CORS_PROXY=https://corsproxy.io/?url=
